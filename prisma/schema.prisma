generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  username    String   @unique
  email       String   @unique
  name        String
  bio         String?
  avatarUrl   String?
  isPrivate   Boolean  @default(false)
  instagramAccessToken String?
  instagramUserId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  checkins      Checkin[]
  itineraries   Itinerary[]
  following     Follow[]      @relation("follower")
  followers     Follow[]      @relation("following")
  profileVector UserProfile?
  matchesFrom   UserMatch[]   @relation("matchUser")
  matchesTo     UserMatch[]   @relation("matchedUser")

  @@index([username])
}

model Location {
  id            String  @id @default(cuid())
  googlePlaceId String? @unique
  name          String
  address       String?
  lat           Float
  lng           Float
  placeType     String  // restaurant | bar | museum | park | hotel | beach | other
  city          String
  neighborhood  String?
  country       String
  countryCode   String  // ISO 3166-1 alpha-2
  googleMapsUrl String?

  checkins Checkin[]

  @@index([city])
  @@index([countryCode])
}

model Checkin {
  id              String   @id @default(cuid())
  userId          String
  locationId      String
  rating          Float    // 1.0 – 5.0
  reviewText      String?
  occasionTag     String?  // food | culture | nightlife | adventure | sightseeing | luxury
  visitedDate     DateTime @default(now())
  photoUrls       String[]
  instagramPostId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  location       Location        @relation(fields: [locationId], references: [id])
  itineraryItems ItineraryItem[]

  @@index([userId])
  @@index([locationId])
  @@index([visitedDate])
}

model Itinerary {
  id          String    @id @default(cuid())
  userId      String
  title       String
  description String?
  destination String    // city or region
  startDate   DateTime?
  endDate     DateTime?
  visibility  String    @default("draft") // draft | public
  forkedFromId String?
  tags        String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  forkedFrom Itinerary?      @relation("forks", fields: [forkedFromId], references: [id])
  forks      Itinerary[]     @relation("forks")
  items      ItineraryItem[]

  @@index([userId])
  @@index([destination])
  @@index([visibility])
}

model ItineraryItem {
  id           String  @id @default(cuid())
  itineraryId  String
  checkinId    String?
  locationName String  // denormalized so items survive location edits
  notes        String?
  dayNumber    Int?
  orderIndex   Int     @default(0)

  itinerary Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  checkin   Checkin?  @relation(fields: [checkinId], references: [id], onDelete: SetNull)

  @@index([itineraryId])
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("follower",  fields: [followerId],  references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
}

// Materialized user feature vectors for match algorithm
model UserProfile {
  userId     String   @id
  vectorJson Json     // UserProfileVector (see src/lib/match/vectors.ts)
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Cached pairwise match scores — recomputed nightly + on check-in
model UserMatch {
  userId        String
  matchedUserId String
  score         Float
  detailsJson   Json     // { geo, taste, style, engagement }
  createdAt     DateTime @default(now())

  user        User @relation("matchUser",    fields: [userId],        references: [id], onDelete: Cascade)
  matchedUser User @relation("matchedUser",  fields: [matchedUserId], references: [id], onDelete: Cascade)

  @@id([userId, matchedUserId])
  @@index([userId, score(sort: Desc)])
}
