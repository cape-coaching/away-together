# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real secrets.

# ── Database ──────────────────────────────────────────────────────────────────
# Get from Supabase: Settings > Database > Connection string (URI)
DATABASE_URL="postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth — console.cloud.google.com > APIs & Services > Credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Apple Sign-In — developer.apple.com > Certificates > Sign In with Apple
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME="away-together-photos"
# CloudFront distribution URL (or use S3 public URL for dev)
CLOUDFRONT_URL="https://your-cdn.cloudfront.net"

# ── Mapbox ────────────────────────────────────────────────────────────────────
# account.mapbox.com > Tokens
NEXT_PUBLIC_MAPBOX_TOKEN="pk.eyJ1..."

# ── Google Places ─────────────────────────────────────────────────────────────
# console.cloud.google.com > Places API
GOOGLE_PLACES_API_KEY=""

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
# console.upstash.com > Redis > Connect > REST API
REDIS_URL="rediss://..."
REDIS_TOKEN=""
